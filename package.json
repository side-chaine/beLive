{
  "name": "belive",
  "version": "0.2.0",
  "description": "beLive — Open Source Art Platform for musicians",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && cp -r js dist/js",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11",
    "zod": "^4.3.6",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^0.20.5",
    "vite-tsconfig-paths": "^5.1.4",
    "workbox-window": "^7.4.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/side-chaine/beLive.git"
  },
  "keywords": ["music", "karaoke", "pwa", "react", "typescript"],
  "author": "Nikita Cheremisinov",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/side-chaine/beLive/issues"
  },
  "homepage": "https://side-chaine.github.io/beLive"
}
