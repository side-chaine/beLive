# Base path для деплоя
# GitHub Pages: /beLive/
# CloudFlare Pages / свой сервер: /
VITE_BASE_PATH=/beLive/

# API Keys
VITE_LASTFM_API_KEY=your_lastfm_api_key_here
VITE_GETSONGBPM_KEY=your_getsongbpm_key_here

# Auth Worker (Google OAuth)
# Production: https://belive-auth.nikitosss007.workers.dev
VITE_AUTH_WORKER_URL=

# Mock Auth (dev only — без Worker)
VITE_USE_MOCK_AUTH=true

# AI Gateway (опционально — без него AI работает только через OpenRouter)
# Dev: http://localhost:8787
# Production: https://your-gateway.workers.dev
VITE_GATEWAY_URL=http://localhost:8787

# beLive AI Worker (built-in AI proxy, requires auth)
# Production: https://belive-ai.nikitosss007.workers.dev
VITE_AI_WORKER_URL=
